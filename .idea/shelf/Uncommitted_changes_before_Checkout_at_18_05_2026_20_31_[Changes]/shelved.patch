+    ]
+
+    if "LEBL" not in airports_db:
+        return -1
+
+    long_distance_aircraft = FilterLongDistance(aircraft, airports_db)
+
+    lat_dest, lon_dest = airports_db["LEBL"]
+
+    if not os.path.exists("output"):
+        os.makedirs("output")
+
+    try:
+        with open("output/flights.kml", "w", encoding="utf-8") as f:
+            f.write("<?xml version='1.0' encoding='UTF-8'?>\n")
+            f.write('<kml xmlns="http://www.opengis.net/kml/2.2">\n')
+            f.write("<Document>\n")
+            f.write("   <name>Vuelos de Larga Distancia (>1000km) a LEBL</name>\n")
+
+            for ac in long_distance_aircraft:
+                orig = ac.origin_airport
+
+                if orig in airports_db:
+                    lat_orig, lon_orig = airports_db[orig]
+
+                    codigo = str(orig[:2])
+                    if codigo in schengen_prefixes:
+                        color = "ffff0000"  # Azul
+                    else:
+                        color = "ff0000ff"  # Rojo
+
+                    f.write("   <Placemark>\n")
+                    f.write(f"   <name>{ac.aircraft_id}</name>\n")
+                    f.write(f"   <Style><LineStyle><color>{color}</color><width>2</width></LineStyle></Style>\n")
+                    f.write("   <LineString>\n")
+                    f.write("   <tessellate>1</tessellate>\n")
+                    f.write("   <coordinates>\n")
+                    f.write(f"      {lon_orig},{lat_orig},0 {lon_dest},{lat_dest},0\n")
+                    f.write("   </coordinates>\n")
+                    f.write("   </LineString>\n")
+                    f.write("   </Placemark>\n")
+
+            f.write("</Document>\n")
+            f.write("</kml>\n")
+        return 0
+    except Exception as e:
+        print(f"Error: {e}")
